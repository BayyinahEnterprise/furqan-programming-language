// PARSE-INVALID — Session 1.2 c.3 patch.
//
// A stray '{' inside an argument list. Before the c.3 patch this
// parsed as `x()` with the brace silently absorbed by the opaque
// arg-list consumer. After the patch the parser rejects with
// "Stray '{' inside call argument list".
//
// Drill-down case 1 from the Perplexity parser review.

bismillah Sloppy {
    authority: NAMING_MD
    serves: purpose_hierarchy.truth_over_falsehood
    scope: orchestrate
    not_scope: parse_files
}

fn run() {
    x({)
}
